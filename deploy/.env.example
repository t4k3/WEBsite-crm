# ==========================================
#  WAZLLEY - Configurazione deploy FTP
#  Copia questo file in "deploy/.env" e compila i valori.
#  deploy/.env NON viene mai committato (vedi .gitignore).
# ==========================================

# Host FTP (senza ftp:// davanti). Es: ftp.takeoff.pro
FTP_HOST=

# Utente FTP (consigliato un utente dedicato al solo subdominio)
FTP_USER=

# Password FTP — viaggia in chiaro (FTP semplice). Non condividerla in chat.
FTP_PASS=

# Cartella sul server che corrisponde a wazlley.takeoff.pro
# Spesso è qualcosa tipo /  oppure /wazlley  oppure /public_html/wazlley
FTP_REMOTE_DIR=/
