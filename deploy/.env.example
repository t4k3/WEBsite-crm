# ==========================================
#  WAZLLEY — Configurazione deploy
#  Copia questo file in "deploy/.env" e compila i valori.
#  deploy/.env NON viene mai committato (vedi .gitignore).
#  Le credenziali le fornisce il titolare del progetto.
# ==========================================

# --- SSH / rsync: è il metodo di pubblicazione da usare ---
SSH_HOST=e36797-ssh.services.easyname.eu
SSH_PORT=11001
SSH_USER=e36797
SSH_REMOTE_DIR=/data/web/e36797/html/wazlley

# La password SSH va in un file separato, deploy/.ssh_pass (anch'esso gitignorato):
#   echo 'LA_PASSWORD' > deploy/.ssh_pass && chmod 600 deploy/.ssh_pass

# --- FTP: legacy, NON usare ---
# Su questo hosting l'FTP è inaffidabile: il canale dati si blocca e satura
# le connessioni del server. Resta solo per compatibilità con deploy/sync.sh.
FTP_HOST=
FTP_USER=
FTP_PASS=
FTP_REMOTE_DIR=/
