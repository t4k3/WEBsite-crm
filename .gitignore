# ==========================================
# WAZLLEY PROJECT - .gitignore
# ==========================================

# ========== SYSTEM FILES ==========
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ========== IDE / EDITOR ==========
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.project
.settings/
.classpath

# ========== NODE (se usato in futuro) ==========
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ========== PHP ==========
*.log
composer.phar
vendor/

# ========== BACKUP / TEMP ==========
*.bak
*.tmp
*.temp
*.old
*_backup.*
backup/
temp/
tmp/

# ========== SENSITIVE DATA ==========
# Aggiungi qui file con credenziali se necessario
# config.php
.env
deploy/.env

# ========== DEPLOY (FTP) ==========
_live_backup/
.lftp-log

# ========== FOTO SORGENTE (non vanno sul sito) ==========
images/
assets/raw/

# ========== BUILD / DIST ==========
dist/
build/
*.min.js
*.min.css

# ========== DEPLOYMENT ==========
.ftpconfig
.deployrc
sftp-config.json

# ========== LOGS ==========
logs/
*.log
error_log
access_log

# ========== CACHE ==========
cache/
.cache/
*.cache

# ========== ALTRI ==========
.htpasswd
